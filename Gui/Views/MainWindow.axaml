<Window x:Class="Gui.Views.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:views="using:Gui.Views"
	xmlns:vm="using:Gui.ViewModels"
	Title="{Binding WindowTitle}" Width="1920" Height="1080" d:DesignHeight="900" d:DesignWidth="1440" Icon="/Assets/loco_icon.png" x:DataType="vm:MainWindowViewModel" mc:Ignorable="d">
	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>
	<views:MainView/>
</Window>

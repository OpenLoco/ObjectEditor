<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:Gui.ViewModels.Loco.Objects.Vehicle"
	xmlns:pgc="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
	xmlns:vi="using:Gui.Views"
	x:Class="Gui.Views.VehicleView"
	x:DataType="vm:VehicleViewModel">

	<Design.DataContext>
		<vm:DesignVehicleViewModel/>
	</Design.DataContext>

	<vi:ExtendedPropertyGrid DataContext="{Binding}" IsCategoryVisible="True" IsHeaderVisible="True" IsQuickFilterVisible="True"/>
</UserControl>
